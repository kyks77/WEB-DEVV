<!DOCTYPE html>
<html>
    <head>
        <title>LIST</title>

        <style>
            ul {
                overflow: hidden;
                background-color: #FF00004F;
            }

            ol {
                overflow: hidden;
                background-color: #00FF004F;
            }

            dl {
                overflow: hidden;
                background-color: #0000FF4F;
            }
        </style>
    </head>

    <body>
        <ol>
            <li>Coffee</li>
            <li>Tea</li>
            <li>Milk</li>

            <hr>

            <ol type="a">
                <li>Coffee</li>
                <li>Tea</li>
                <li>Milk</li>
            </ol>

            <ol type="A">
                <li>Coffee</li>
                <li>Tea</li>
                <li>Milk</li>
            </ol>

            <ol type="i">
                <li>Coffee</li>
                <li>Tea</li>
                <li>Milk</li>
            </ol>
 
            <ol type="I">
                <li>Coffee</li>
                <li>Tea</li>
                <li>Milk</li>
            </ol>
 
            <ol type="1">
                <li>Coffee</li>
                <li>Tea</li>
                <li>Milk</li>
            </ol>
 
            <ol start="99">
                <li>Coffee</li>
                <li>Tea</li>
                <li>Milk</li>
            </ol>
 
        </ol>

        <hr>

        <ul>
            <li>Coffee</li>
            <li>Tea</li>
            <li>Milk</li>

            <hr>

            <ul style="list-style-type: disc;">
                <li>Coffee</li>
                <li>Tea</li>
                <li>Milk</li>
            </ul>

            <ul style="list-style-type: square;">
                <li>Coffee</li>
                <li>Tea</li>
                <li>Milk</li>
            </ul>

            <ul style="list-style-type: circle;">
                <li>Coffee</li>
                <li>Tea</li>
                <li>Milk</li>
            </ul>

            <ul style="list-style-type: none;">
                <li>Coffee</li>
                <li>Tea</li>
                <li>Milk</li>
            </ul>


        </ul>

        <hr>

        <dl>
            <dt>Coffee</dt>
                <dd>- it is black</dd>
            <dt>Milk</dt>
                <dd>- it is white</dd>
        </dl>
    </body>
</html>

